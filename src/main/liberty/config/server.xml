<?xml version="1.0" encoding="UTF-8"?>
<server description="Hello World Servlet Server">

    <!-- Enable features -->
    <featureManager>
        <feature>servlet-6.0</feature>
        <feature>jsp-3.1</feature>
    </featureManager>

    <!-- HTTP Endpoint -->
    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="${http.port}"
                  httpsPort="${https.port}" />

    <!-- Web Application -->
    <webApplication id="hello-world-servlet"
                    location="hello-world-servlet.war"
                    contextRoot="/" />

    <!-- Automatically expand WAR files and EAR files -->
    <applicationManager autoExpand="true"/>

    <!-- Logging -->
    <logging traceSpecification="*=info"
             maxFileSize="20"
             maxFiles="10" />

</server>
